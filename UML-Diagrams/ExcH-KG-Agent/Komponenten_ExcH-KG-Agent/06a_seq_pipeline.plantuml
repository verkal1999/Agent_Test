@startuml

skinparam shadowing false
skinparam responseMessageBelowArrow true
skinparam sequenceMessageAlign center
hide footbox
autonumber

title ExcH-KG-Agent - Initiale Anfrage\nTeil 1 von 6:\nPipeline-Vorbereitung

boundary "ExcHAgent\nUI" as UI
control "Pipeline" as Pipeline
entity "Pipeline\nContext" as Ctx
control "ExportPLCopenXML\nStep" as ExportStep
control "BuildProgramIO\nMappingStep" as ProgStep
control "BuildIOMappings\nStep" as IoStep
control "ArtifactQuality\nGate" as Gate

UI -> Pipeline : run(\nctx)
activate Pipeline
create Ctx
Pipeline -> Ctx : create artifacts = {}

Pipeline -> ExportStep : run(\nCtx)
activate ExportStep
ExportStep -> Ctx : set("plcopen_xml", ...)
ExportStep --> Pipeline : Export abgeschlossen
deactivate ExportStep

Pipeline -> ProgStep : run(\nCtx)
activate ProgStep
ProgStep -> Ctx : set("program_\nmapping", ...)\nset("gvl", ...)
ProgStep --> Pipeline : Mapping-Artefakte bereit
deactivate ProgStep

Pipeline -> IoStep : run(\nCtx)
activate IoStep
IoStep -> Ctx : set("io_\nmappings", ...)
IoStep --> Pipeline : Hardware-Bezuege bereit
deactivate IoStep

Pipeline -> Gate : validate(\nCtx)
activate Gate
Gate --> Pipeline : Artefakte freigegeben
deactivate Gate
Pipeline --> UI : PipelineContext bereit
deactivate Pipeline

note right of Ctx
Alle Ingestion-Schritte
arbeiten auf demselben
gemeinsamen Kontext.
end note

@enduml
