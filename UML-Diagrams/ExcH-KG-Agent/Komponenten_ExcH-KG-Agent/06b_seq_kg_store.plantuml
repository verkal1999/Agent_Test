@startuml

skinparam shadowing false
skinparam responseMessageBelowArrow true
skinparam sequenceMessageAlign center
hide footbox
autonumber

title ExcH-KG-Agent - Initiale Anfrage\nTeil 2 von 6:\nKG-Befuellung und Anreicherung

boundary "ExcHAgent\nUI" as UI
control "KG\nLoader" as Loader
control "KG\nManager" as Manager
database "KG\nStore" as Store

UI -> Loader : ingest Artefakte\naus Pipeline\nContext
activate Loader
Loader -> Store : build_gvl_index_\nfrom_objects()
Loader -> Store : ingest_programs_\nfrom_mapping_json()
Loader -> Store : ingest_io_\nmappings()
Loader -> Store : ingest_gvl_\nglobals()
Loader -> Store : save()
Loader --> UI : Graph-Basis erstellt
deactivate Loader

UI -> Manager : load()
activate Manager
Manager -> Store : lade RDF-Graph
Store --> Manager : graph

UI -> Manager : analyze_unused_\nelements()
Manager -> Store : analysiere und erweitere

UI -> Manager : generate_\nreports()
Manager -> Store : erzeuge Zusatzwissen

UI -> Manager : save(\noutput_path)
Manager -> Store : persistiere Graph
Manager --> UI : KG einsatzbereit
deactivate Manager

@enduml
