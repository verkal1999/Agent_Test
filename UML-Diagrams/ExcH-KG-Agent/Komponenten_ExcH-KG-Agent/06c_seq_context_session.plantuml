@startuml

skinparam shadowing false
skinparam responseMessageBelowArrow true
skinparam sequenceMessageAlign center
hide footbox
autonumber

title ExcH-KG-Agent - Initiale Anfrage\nTeil 3 von 6:\nKontext- und Sitzungsaufbau

actor "Nutzende\nInstanz" as User
collections "RuntimeEvent" as Event
boundary "ExcHAgent\nUI" as UI
control "Context\nAssembler" as Assembler
entity "Incident\nContext" as Ctx
control "ExcHChatBot\nSession" as Session
entity "Session\nMemory" as Memory

User -> UI : start_analysis(\nevent)
activate UI
UI -> Event : lese Fehlerereignis

UI -> Assembler : from_event(\nevent)
activate Assembler
create Ctx
Assembler -> Ctx : create\nIncidentContext\n+\nRuntimeSnapshot\n+\nGraphContextRef
Assembler --> UI : ctx
deactivate Assembler

create Session
UI -> Session : create(\nbot,\nctx)
activate Session
create Memory
Session -> Memory : create\nbootstrap_plan = None,\nturns = []
Session --> UI : Sitzung bereit
deactivate Session
deactivate UI

@enduml
