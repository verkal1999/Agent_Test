@startuml

skinparam shadowing false
skinparam responseMessageBelowArrow true
skinparam sequenceMessageAlign center
hide footbox
autonumber

title ExcH-KG-Agent - Initiale Anfrage\nTeil 4 von 6:\nBootstrap-Planung

boundary "ExcHAgent\nUI" as UI
control "ExcHChatBot\nSession" as Session
control "Planner" as Planner
entity "Analysis\nPlan" as Plan
entity "Session\nMemory" as Memory

UI -> Session : ensure_bootstrap_\nplan()
activate Session
Session -> Planner : plan(\nctx)
activate Planner
create Plan
Planner -> Plan : create goal\n+\nPlanStep[]
Planner --> Session : AnalysisPlan
deactivate Planner

Session -> Memory : speichere bootstrap_plan
Session --> UI : initialer Analyseplan bereit
deactivate Session

@enduml
