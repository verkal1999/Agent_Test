@startuml

skinparam shadowing false
skinparam responseMessageBelowArrow true
skinparam sequenceMessageAlign center
hide footbox
autonumber

title ExcH-KG-Agent - Initiale Anfrage\nTeil 4 von 6: Bootstrap-Planung

boundary "ExcHAgentUI" as UI
control "ExcHChatBotSession" as Session
control "Planner" as Planner
entity "AnalysisPlan" as Plan
entity "SessionMemory" as Memory

UI -> Session : ensure_bootstrap_plan()
activate Session
Session -> Planner : plan(ctx)
activate Planner
create Plan
Planner -> Plan : create goal + PlanStep[]
Planner --> Session : AnalysisPlan
deactivate Planner

Session -> Memory : speichere bootstrap_plan
Session --> UI : initialer Analyseplan bereit
deactivate Session

@enduml
