@startuml

skinparam shadowing false
skinparam responseMessageBelowArrow true
skinparam sequenceMessageAlign center
hide footbox
autonumber

title ExcH-KG-Agent - Initiale Anfrage\nTeil 5 von 6:\nWerkzeugausfuehrung und Synthese

control "ExcH\nChatBot\nSession" as Session
control "Tool\nRegistry" as Registry
control "KGQuery\nTool" as KGTool
control "StructureCode\nAnalysisTool" as StructTool
control "Variable\nSignal\nAnalysisTool" as SignalTool
control "Path\nReconstruction\nTool" as PathTool
entity "Tool\nResult\nBundle" as Results
control "Foundation\nModel\nAdapter" as FM

create Results
Session -> Results : create empty result bundle
activate Session

Session -> Registry : execute(\n"KGQueryTool",\nargs)
activate Registry
Registry -> KGTool : run(...)
activate KGTool
KGTool --> Registry : semantische Treffer
deactivate KGTool
Registry --> Session : tool result
deactivate Registry
Session -> Results : add(KGQueryTool)

Session -> Registry : execute(\n"StructureCodeAnalysisTool",\nargs)
activate Registry
Registry -> StructTool : run(...)
activate StructTool
StructTool --> Registry : Code- und POU-Kontext
deactivate StructTool
Registry --> Session : tool result
deactivate Registry
Session -> Results : add(StructureCodeAnalysisTool)

Session -> Registry : execute(\n"VariableSignalAnalysisTool",\nargs)
activate Registry
Registry -> SignalTool : run(...)
activate SignalTool
SignalTool --> Registry : Variablen- und Portbelege
deactivate SignalTool
Registry --> Session : tool result
deactivate Registry
Session -> Results : add(VariableSignalAnalysisTool)

Session -> Registry : execute(\n"PathReconstructionTool",\nargs)
activate Registry
Registry -> PathTool : run(...)
activate PathTool
PathTool --> Registry : Fehlerpfade
deactivate PathTool
Registry --> Session : tool result
deactivate Registry
Session -> Results : add(PathReconstructionTool)

Session -> FM : synthesize(ctx,plan,results)
activate FM
FM --> Session : diagnosis draft
deactivate FM
deactivate Session

@enduml
