@startuml

skinparam shadowing false
skinparam responseMessageBelowArrow true
skinparam sequenceMessageAlign center
hide footbox
autonumber

title ExcH-RAG-Agent - Initiale Anfrage\nTeil 1 von 6:\nSitzungs- und Kontextaufbau

actor "Nutzende\nInstanz" as User
collections "RuntimeEvent" as Event
boundary "RagAgent\nUI" as UI
control "RagSession\nBuilder" as Builder
control "Context\nInterpreter" as CtxInt
entity "RagIncident\nContext" as Ctx
control "SimpleRag\nSession" as Session

User -> UI : start_analysis(\nevent)
activate UI
UI -> Event : lese Fehlerereignis

opt PipelineConfig.enabled
  UI -> UI : run_pipeline(\ncfg.pipeline,\nevent)
  UI -> Event : payload.plcopen_\nxml_path\naktualisieren
end

UI -> Builder : build_session_\nfrom_input(\nevent,\nxml_path,\nmodel,\ntemperature,\ntop_k)
activate Builder
Builder -> CtxInt : from_event(\nevent)
activate CtxInt
CtxInt -> CtxInt : extract_\nsnapshot(\nevent)
create Ctx
CtxInt -> Ctx : create\nRagIncidentContext\n+\nRuntimeSnapshot
CtxInt --> Builder : ctx
deactivate CtxInt

create Session
Builder -> Session : create(\nctx,\nconfig)
Builder --> UI : Session bereit
deactivate Builder
deactivate UI

@enduml
