@startuml

skinparam shadowing false
skinparam responseMessageBelowArrow true
skinparam sequenceMessageAlign center
hide footbox
autonumber

title ExcH-RAG-Agent - Initiale Anfrage\nTeil 2 von 6:\nArtefaktaufbereitung

control "RagSession\nBuilder" as Builder
entity "Artifact\nCatalog" as Catalog
control "PLCOpenXml\nSource" as XmlSource
control "XmlChunker" as Chunker
entity "Document\nCorpus" as Corpus
control "SimpleRag\nIndex" as Index

create Catalog
Builder -> Catalog : create(\nxml_path,\ndocument_type =\n"PLCOpenXML")
activate Builder

Builder -> XmlSource : load_text(\nxml_path)
activate XmlSource
XmlSource --> Builder : xml_text
deactivate XmlSource

Builder -> Chunker : chunk_text(\nxml_text,\nxml_path)
activate Chunker
Chunker --> Builder : RagChunk[]
deactivate Chunker

create Corpus
Builder -> Corpus : add(\nchunks)

Builder -> Index : create(\nchunks)
Index --> Builder : Index bereit
deactivate Builder

@enduml
