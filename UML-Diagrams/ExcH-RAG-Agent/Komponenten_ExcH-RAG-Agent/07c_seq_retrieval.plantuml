@startuml

skinparam shadowing false
skinparam responseMessageBelowArrow true
skinparam sequenceMessageAlign center
hide footbox
autonumber

title ExcH-RAG-Agent - Initiale Anfrage\nTeil 3 von 6:\nRetrieval

control "SimpleRag\nSession" as Session
entity "RagIncident\nContext" as Ctx
entity "Retrieval\nQuery" as Query
control "SimpleRag\nIndex" as Index
control "Token\nScorer" as Scorer
entity "RetrievalResult\nSet" as ResultSet

Session -> Ctx : default_\nquestion()
activate Session
Ctx --> Session : initiale Diagnosefrage

Session -> Ctx : compact_event_\ncontext()
Ctx --> Session : kompakter Event-Kontext

Session -> Ctx : runtime_context_\nnote()
Ctx --> Session : Laufzeit- und Snapshot-Hinweise

create Query
Session -> Query : create(\nquestion,\ntop_k)
Session -> Index : search(\nquestion,\ntop_k)
activate Index

loop fuer jedes relevante Dokumentsegment
  Index -> Scorer : score(\nquery,\nchunk)
  activate Scorer
  Scorer --> Index : Relevanzwert
  deactivate Scorer
end

create ResultSet
Index -> ResultSet : create\nranked hits
ResultSet --> Session : RetrievalResultSet
deactivate Index
deactivate Session

@enduml
