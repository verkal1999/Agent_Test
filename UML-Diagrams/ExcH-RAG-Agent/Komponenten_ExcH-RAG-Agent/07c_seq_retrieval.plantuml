@startuml

skinparam shadowing false
skinparam responseMessageBelowArrow true
skinparam sequenceMessageAlign center
hide footbox
autonumber

title ExcH-RAG-Agent - Initiale Anfrage\nTeil 3 von 6: Retrieval

control "SimpleRagSession" as Session
entity "RagIncidentContext" as Ctx
entity "RetrievalQuery" as Query
control "SimpleRagIndex" as Index
control "TokenScorer" as Scorer
entity "RetrievalResultSet" as ResultSet

Session -> Ctx : default_question()
activate Session
Ctx --> Session : initiale Diagnosefrage

Session -> Ctx : compact_event_context()
Ctx --> Session : kompakter Event-Kontext

Session -> Ctx : runtime_context_note()
Ctx --> Session : Laufzeit- und Snapshot-Hinweise

create Query
Session -> Query : create(question, top_k)
Session -> Index : search(question, top_k)
activate Index

loop fuer jedes relevante Dokumentsegment
  Index -> Scorer : score(query, chunk)
  activate Scorer
  Scorer --> Index : Relevanzwert
  deactivate Scorer
end

create ResultSet
Index -> ResultSet : create ranked hits
ResultSet --> Session : RetrievalResultSet
deactivate Index
deactivate Session

@enduml
