@startuml

skinparam shadowing false
skinparam responseMessageBelowArrow true
skinparam sequenceMessageAlign center
hide footbox
autonumber

title ExcH-RAG-Agent - Initiale Anfrage\nTeil 4 von 6:\nKontextbuendelung und Guardrails

control "SimpleRag\nSession" as Session
entity "Generation\nRequest" as GenReq
entity "GroundedContext\nBundle" as Bundle
entity "RetrievedContext\nBlock" as Block
control "GroundedAnswer\nGenerator" as Generator
control "Guardrail\nPolicy" as Guard
entity "Answer\nContract" as Contract

create GenReq
Session -> GenReq : create(\nquestion,\nextra_context)
activate Session

create Bundle
Session -> Bundle : create(\nevent_context,\nretrieved_chunks)

create Block
Session -> Block : create(\nrank,\nkind,\nname,\nscore,\ntext)
Session -> Bundle : add\nRetrievedContext\nBlock[]

Session -> Generator : generate(\nreq,\nbundle)
activate Generator
Generator -> Guard : enforce(\nreq)
activate Guard
Guard --> Generator : guarded req
deactivate Guard

Generator -> Contract : lese\nrequired_sections
activate Contract
Contract --> Generator : Antwortstruktur
deactivate Contract
deactivate Generator
deactivate Session

@enduml
