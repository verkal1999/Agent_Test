@startuml

skinparam shadowing false
skinparam responseMessageBelowArrow true
skinparam sequenceMessageAlign center
hide footbox
autonumber

title ExcH-RAG-Agent - Initiale Anfrage\nTeil 6 von 6:\nErgebnis und Ausgabe

actor "Nutzende\nInstanz" as User
control "GroundedAnswer\nGenerator" as Generator
control "Guardrail\nPolicy" as Guard
entity "Generation\nResult" as Result
control "SimpleRag\nSession" as Session
entity "Chat\nTurn" as Turn
boundary "RagAgent\nUI" as UI

create Result
Generator -> Result : create(\nanswer,\nuncertainty_\nnotes)
activate Generator
Generator -> Guard : validate(\nresult)
activate Guard
Guard --> Generator : ok / Unsicherheit markiert
deactivate Guard

Generator --> Session : GenerationResult
deactivate Generator
activate Session

create Turn
Session -> Turn : create(\nrole="user",\ntext,\nanswer)
Session --> UI : erste Diagnose\n+\nretrieval\ndebug
deactivate Session
activate UI

UI --> User : auto-generierte Erstfrage\n+ erste Diagnoseantwort
deactivate UI

@enduml
